FLASK_ENV=production
PORT=10000

# --- Conexión a la RDS de sico (esquema sco) ---
# Se conecta directo con las credenciales existentes (como DBeaver); no hay un
# usuario de solo-lectura dedicado. La protección contra escrituras es a nivel
# de sesión: cada conexión se pone en READ ONLY automáticamente.
SICO_DB_HOST=mappale-sico.cdngbntx2q8s.us-west-2.rds.amazonaws.com
SICO_DB_PORT=3306
SICO_DB_USER=
SICO_DB_PASSWORD=
# Poner en 'require' si se decide forzar TLS hacia la RDS.
SICO_DB_SSL=

# El usuario configurado tiene privilegios de escritura (cuenta compartida).
# Este flag confirma de forma explícita que se acepta conectar con una cuenta
# privilegiada. Sin él, el backend se niega a arrancar si detecta un usuario
# con permisos de escritura (protección contra usarlo por accidente).
SICO_ALLOW_WRITE_USER=true

# Tiempo máximo por celda (segundos) antes de cortar la ejecución.
CELL_TIMEOUT_SECONDS=15
